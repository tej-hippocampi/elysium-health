# ═══════════════════════════════════════════════════════════
#  CareGuide — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ── Anthropic (Claude) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs (voice synthesis) ────────────────────────────
ELEVENLABS_API_KEY=...
# Choose a warm, calm clinical voice from ElevenLabs voice library
ELEVENLABS_VOICE_ID=l4Coq6695JDX9xtLqXDE

# ── Tavus (AI avatar) ────────────────────────────────────────
TAVUS_API_KEY=...
# Your licensed replica ID (the visual avatar face/body)
TAVUS_REPLICA_ID=r...

# ── Twilio (SMS delivery) ────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ── App ──────────────────────────────────────────────────────
# Public URL where patients will access their dashboard
BASE_URL=https://app.careguide.com
# Secret for JWT signing (landing / Elysium Health auth). Use a long random string in production.
AUTH_SECRET=change-me-in-production-elysium
# Care team callback number shown in the dashboard footer
CARE_TEAM_PHONE=+1...
